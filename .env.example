# Environment
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Server
PORT=3000

# Sentry (error monitoring) — leave blank to disable entirely, Sentry.init()
# no-ops when there's no DSN. Get these from your Sentry project settings.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Only needed in CI/production builds to upload source maps
SENTRY_AUTH_TOKEN=
